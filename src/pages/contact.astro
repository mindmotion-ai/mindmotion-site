---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Base
  title="Contact | MindMotion"
  description="Get in touch with MindMotion."
>
  <Nav />
  <main id="main">
    <section id="contact-default-heading" class="reveal pt-16 md:pt-24 pb-8 md:pb-12 px-6">
      <div class="max-w-[960px] mx-auto">
        <h1 class="text-3xl md:text-4xl font-semibold text-accent leading-[1.1] tracking-tight">
          Contact
        </h1>
      </div>
    </section>

    <section id="contact-form-section" class="reveal pb-14 md:pb-24 px-6">
      <div class="max-w-[960px] mx-auto">
        <ContactForm />
      </div>
    </section>

    <section id="contact-thanks-section" class="reveal pt-16 md:pt-24 pb-14 md:pb-24 px-6" hidden>
      <div class="max-w-[960px] mx-auto">
        <h1 class="text-3xl md:text-4xl font-semibold text-accent leading-[1.1] tracking-tight">
          Thank you
        </h1>
        <p class="mt-4 md:mt-5 text-base sm:text-lg md:text-xl text-accent-2 leading-snug">
          We have received your message and will respond shortly.
        </p>
      </div>
    </section>
  </main>

  <script is:inline>
    document.addEventListener('mindmotion:contact-success', () => {
      const heading = document.getElementById('contact-default-heading');
      const form = document.getElementById('contact-form-section');
      const thanks = document.getElementById('contact-thanks-section');
      if (heading) heading.hidden = true;
      if (form) form.hidden = true;
      if (thanks) {
        thanks.hidden = false;
        requestAnimationFrame(() => thanks.classList.add('is-visible'));
        thanks.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  </script>
  <Footer />
</Base>
