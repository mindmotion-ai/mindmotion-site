---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Section from '../components/Section.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Base
  title="Contact | MindMotion, Inc."
  description="Get in touch with MindMotion."
>
  <Nav />
  <main id="main">
    <Section
      id="contact-form-section"
      heading="Contact"
      headingLevel={1}
    >
      <div class="mt-8 md:mt-12">
        <ContactForm />
      </div>
    </Section>

    <Section
      id="contact-thanks-section"
      heading="Thank you"
      headingLevel={1}
      hidden
    >
      <p class="text-base sm:text-lg md:text-xl text-accent-2 leading-snug">
        We have received your message and will respond shortly.
      </p>
    </Section>
  </main>

  <script is:inline>
    document.addEventListener('mindmotion:contact-success', () => {
      const formSection = document.getElementById('contact-form-section');
      const thanks = document.getElementById('contact-thanks-section');
      if (formSection) formSection.hidden = true;
      if (thanks) {
        thanks.hidden = false;
        requestAnimationFrame(() => thanks.classList.add('is-visible'));
        thanks.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  </script>
  <Footer />
</Base>
