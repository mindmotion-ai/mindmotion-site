---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Base
  title="Contact | MindMotion"
  description="Get in touch with MindMotion."
>
  <Nav />
  <main id="main">
    <section class="pt-16 md:pt-24 pb-8 md:pb-12 px-6">
      <div class="max-w-[960px] mx-auto">
        <h1 class="text-3xl md:text-4xl font-semibold text-accent leading-[1.1] tracking-tight">
          Contact
        </h1>
      </div>
    </section>

    <section class="pb-14 md:pb-24 px-6">
      <div class="max-w-[960px] mx-auto">
        <ContactForm />
      </div>
    </section>
  </main>
  <Footer />
</Base>
