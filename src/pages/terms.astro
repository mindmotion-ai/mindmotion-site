---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import Footer from '../components/Footer.astro';

const effectiveDate = 'May 19, 2026';
---

<Base
  title="Terms of Service | MindMotion"
  description="Terms of service for the MindMotion website."
>
  <Nav />
  <main id="main" class="fade-in-up">
    <PageHeader
      title="Terms of Service"
      subtitle="Terms governing access to and use of this website."
      density="compact"
    />

    <Section density="compact">
      <p><strong>Effective:</strong> {effectiveDate}</p>
      <p>
        These Terms of Service ("Terms") govern your access to and use
        of https://mindmotion.ai (the "Site"), operated by MindMotion,
        Inc. ("MindMotion," "we," "us," or "our"). By accessing or
