---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Page not found | MindMotion"
  description="The page you requested could not be found."
>
  <Nav />
  <main
    id="main"
    class="min-h-[60vh] flex flex-col items-center justify-center px-6 text-center"
  >
    <p class="text-sm text-accent-2 mb-2 tracking-wide uppercase">404</p>
    <h1 class="text-3xl md:text-4xl font-semibold mb-6 text-accent">
      Page not found
    </h1>
    <p class="text-lg max-w-md mb-8 text-accent-2">
      The page you requested could not be found.
    </p>
    <a href="/" class="text-link">Return to home &rarr;</a>
  </main>
  <Footer />
</Base>
