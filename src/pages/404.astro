---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Page not found | MindMotion, Inc."
  description="The page you requested could not be found."
  noindex
>
  <Nav />
  <main
    id="main"
    class="fade-in-up min-h-[60vh] flex flex-col items-center justify-center px-5 sm:px-6 text-center"
  >
    <h1 class="text-2xl md:text-3xl font-semibold text-accent leading-tight tracking-tight mb-6">
      The page you requested could not be found
    </h1>
    <a href="/" class="text-accent font-semibold hover:text-link">Return to home</a>
  </main>
  <Footer />
</Base>
