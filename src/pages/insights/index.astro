---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';
import InsightCard from '../../components/InsightCard.astro';
import { SITE } from '../../config.ts';

const allPosts = await getCollection('insights', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const readingTime = (text: string) => {
  const words = (text ?? '').trim().split(/\s+/).filter(Boolean).length;
  const minutes = Math.max(1, Math.round(words / 200));
  return `${minutes} min read`;
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE.url,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Insights',
      item: new URL('/insights/', SITE.url).toString(),
    },
  ],
};
---

<Base
  title="Insights | MindMotion, Inc."
  description="Why safety has to live outside the AI for AI-driven robots to be deployed around people."
>
  <Nav />
  <main id="main">
    <PageHeader
      title="Safety infrastructure for AI-driven robots"
      density="compact"
    />

    {sortedPosts.length === 0 ? (
      <Section density="compact">
        <p class="text-base text-accent-2">No posts yet.</p>
      </Section>
    ) : (
      sortedPosts.map((post, i) => (
        <Section
          variant={i % 2 === 1 ? 'tinted' : 'default'}
          class={i === 0 ? '!pt-12 md:!pt-16' : ''}
        >
          <InsightCard
            slug={post.id}
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            readingTime={readingTime(post.body ?? '')}
          />
        </Section>
      ))
    )}
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(breadcrumbJsonLd)}
    />
  </main>
  <Footer />
</Base>
