---
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
---

<form id="contact-form" class="space-y-7" novalidate>
  <input type="hidden" name="access_key" value={accessKey} />
  <input
    type="checkbox"
    name="botcheck"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
    style="position:absolute;left:-9999px"
  />

  <div>
    <label for="name" class="block text-base font-medium text-accent mb-2">
      Name
    </label>
    <input
      id="name"
      type="text"
      name="name"
      required
      autocomplete="name"
      class="w-full px-4 py-3 bg-white border border-accent/20 rounded-md focus:outline-none focus:border-accent transition-colors text-base"
    />
  </div>

  <div>
    <label for="email" class="block text-base font-medium text-accent mb-2">
      Email
    </label>
    <input
      id="email"
      type="email"
      name="email"
      required
      autocomplete="email"
      class="w-full px-4 py-3 bg-white border border-accent/20 rounded-md focus:outline-none focus:border-accent transition-colors text-base"
    />
  </div>

  <div>
    <label for="organization" class="block text-base font-medium text-accent mb-2">
      Organization
    </label>
    <input
      id="organization"
      type="text"
      name="organization"
      required
      autocomplete="organization"
      class="w-full px-4 py-3 bg-white border border-accent/20 rounded-md focus:outline-none focus:border-accent transition-colors text-base"
    />
  </div>

  <div>
    <label for="message" class="block text-base font-medium text-accent mb-2">
      Message
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="7"
      class="w-full px-4 py-3 bg-white border border-accent/20 rounded-md focus:outline-none focus:border-accent transition-colors text-base resize-y"
    ></textarea>
  </div>

  <div class="flex flex-col items-start gap-3">
    <button
      type="submit"
      class="px-7 py-3 bg-accent text-bg rounded-md font-medium hover:bg-accent-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Send
    </button>
    <p class="text-sm text-accent-2">
      By submitting, you agree to our <a href="/privacy">Privacy Policy</a>.
    </p>
  </div>

  <p
    id="contact-error"
    class="text-sm text-accent"
    role="alert"
    aria-live="polite"
    hidden
  >
    Something went wrong. Please try again in a moment.
  </p>
</form>

<div
  id="contact-success"
  class="text-lg text-accent"
  role="status"
  aria-live="polite"
  hidden
>
  <p>Thank you. We have received your message and will respond shortly.</p>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  const error = document.getElementById('contact-error');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !success || !error || !submitBtn) return;

    error.hidden = true;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (res.ok && json.success) {
        form.hidden = true;
        success.hidden = false;
      } else {
        throw new Error(json.message || 'submission failed');
      }
    } catch (err) {
      error.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send';
    }
  });
</script>
