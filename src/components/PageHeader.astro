---
/**
 * Use PageHeader for the top of a page whose role is purely descriptive:
 * a title with an optional one-line subtitle that labels what the page is.
 * Examples on this site: /privacy, /terms, /insights.
 *
 * Do NOT use PageHeader when the page-top element has content immediately
 * attached (Mission's tagline as content) or is stateful and toggled by id
 * via JS (Contact's form / thank-you swap). Those cases use Section with
 * `headingLevel={1}` so the heading and its content share one element.
 */
interface Props {
  title: string;
  subtitle?: string;
  density?: 'normal' | 'compact';
}
const { title, subtitle, density = 'normal' } = Astro.props;

const paddingClass =
  density === 'compact'
    ? 'pt-16 md:pt-24 pb-2 md:pb-4'
    : 'pt-16 md:pt-24 pb-14 md:pb-24';
---

<section class={`reveal ${paddingClass} px-5 sm:px-6`}>
  <div class="max-w-[1080px] mx-auto">
    <h1 class="text-3xl md:text-4xl font-semibold text-accent leading-[1.1] tracking-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-4 md:mt-5 text-base sm:text-lg md:text-xl text-accent-2 leading-snug">
        {subtitle}
      </p>
    )}
  </div>
</section>
