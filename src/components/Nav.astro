---
import { SITE, INSIGHTS_ENABLED } from '../config.ts';
---

<header class="sticky top-0 z-40 bg-bg/85 backdrop-blur">
  <nav class="px-6 py-5" aria-label="Primary">
    <div class="max-w-[1080px] mx-auto flex items-center justify-between">
      <a
        href="/"
        class="flex items-center gap-3 transition-opacity duration-150 hover:opacity-70"
        aria-label={`${SITE.name} home`}
      >
        <img
          src="/logo-mindmotion.svg"
          alt=""
          width="48"
          height="48"
          class="h-12 w-auto"
        />
        <span class="font-semibold text-xl sm:text-2xl text-accent">
          {SITE.name}
        </span>
      </a>
      <ul class="flex items-center gap-6 text-base">
        <li><a href="/about" class="text-accent hover:text-link">About</a></li>
        {INSIGHTS_ENABLED && (
          <li><a href="/insights" class="text-accent hover:text-link">Insights</a></li>
        )}
        <li><a href="/contact" class="text-accent hover:text-link">Contact</a></li>
      </ul>
    </div>
  </nav>
</header>
