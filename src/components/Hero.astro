---
import { SITE } from '../config.ts';
---

<section
  class="hero min-h-[75vh] flex flex-col items-center justify-center px-6 relative overflow-hidden"
  aria-labelledby="hero-tagline"
>
  <div class="flex flex-col items-center text-center fade-in-up max-w-[1080px] relative z-10">
    <h1
      id="hero-tagline"
      class="text-4xl sm:text-5xl md:text-[96px] font-semibold text-accent leading-[1.18] tracking-tight"
    >
      Software for safe<br />robot deployment<br />around people
    </h1>
    <div class="hero-rule mt-8 md:mt-10" aria-hidden="true"></div>
    <p class="text-lg sm:text-xl md:text-[36px] text-accent-2 mt-6 md:mt-8 leading-snug">
      Runtime safety for AI-driven robots
    </p>
  </div>
  <a
    href="#problem"
    aria-label="Scroll to the problem section"
    class="absolute bottom-[3vh] text-accent hover:text-accent transition-colors p-3 z-10 chevron-bounce"
  >
    <svg
      viewBox="0 0 160 30"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="w-[160px] h-auto"
    >
      <defs>
        <linearGradient id="chevronFade" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="currentColor" stop-opacity="0" />
          <stop offset="35%" stop-color="currentColor" stop-opacity="0.4" />
          <stop offset="65%" stop-color="currentColor" stop-opacity="0.4" />
          <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
        </linearGradient>
      </defs>
      <polyline
        points="6 4 80 22 154 4"
        stroke="url(#chevronFade)"
        stroke-width="2"
      ></polyline>
    </svg>
  </a>
</section>

<style>
  .hero {
    background:
      radial-gradient(
        ellipse 70% 55% at 50% 45%,
        rgba(15, 42, 68, 0.06) 0%,
        rgba(15, 42, 68, 0.02) 45%,
        transparent 75%
      );
  }
  .hero-rule {
    width: 160px;
    height: 2px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(15, 42, 68, 0.4),
      transparent
    );
  }
</style>
