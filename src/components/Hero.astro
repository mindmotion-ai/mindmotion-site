---
import { SITE } from '../config.ts';
---

<section
  class="hero min-h-[75vh] flex flex-col items-center justify-center px-6 relative overflow-hidden"
  aria-labelledby="hero-tagline"
>
  <div class="flex flex-col items-center text-center fade-in-up max-w-[1080px] relative z-10 -translate-y-[5vh]">
    <h1
      id="hero-tagline"
      class="text-4xl sm:text-5xl md:text-[96px] font-semibold text-accent leading-[1.18] tracking-tight"
    >
      Safe robot deployment<br />around people
    </h1>
    <div class="hero-rule mt-8 md:mt-10" aria-hidden="true"></div>
    <p class="text-lg sm:text-xl md:text-[36px] text-accent-2 mt-6 md:mt-8 leading-snug">
      Runtime safety software for AI-driven robots
    </p>
  </div>
  <a
    href="#problem"
    aria-label="Scroll to the problem section"
    class="absolute bottom-[6vh] text-accent/35 hover:text-accent transition-colors p-3 z-10 chevron-bounce"
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="h-10 w-10"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>

<style>
  .hero {
    background:
      radial-gradient(
        ellipse 70% 55% at 50% 45%,
        rgba(15, 42, 68, 0.06) 0%,
        rgba(15, 42, 68, 0.02) 45%,
        transparent 75%
      );
  }
  .hero-rule {
    width: 160px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      rgba(15, 42, 68, 0.4),
      transparent
    );
  }
</style>
