---
import { SITE } from '../config.ts';
---

<section
  class="min-h-[95vh] flex flex-col items-center justify-center px-6 relative -mt-[72px] pt-[72px]"
  aria-labelledby="hero-name"
>
  <div class="flex flex-col items-center text-center fade-in-up">
    <img
      src="/logo-mindmotion.svg"
      alt=""
      width="120"
      height="120"
      class="h-20 sm:h-24 md:h-[120px] w-auto mb-12 md:mb-20"
    />
    <h1
      id="hero-name"
      class="text-4xl sm:text-5xl md:text-[64px] font-semibold text-accent leading-none tracking-tight"
    >
      {SITE.name}
    </h1>
    <p class="text-xl sm:text-2xl md:text-[28px] font-semibold text-accent mt-8 md:mt-12 max-w-3xl">
      {SITE.tagline}.
    </p>
    <p class="text-base sm:text-lg md:text-[20px] text-accent-2 mt-2">
      Runtime safety for AI-driven robots.
    </p>
  </div>
  <a
    href="#problem"
    aria-label="Scroll to the problem section"
    class="absolute bottom-[50px] text-accent/40 hover:text-accent transition-colors p-2"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>
