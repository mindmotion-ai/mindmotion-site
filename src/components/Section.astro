---
/**
 * Section is the workhorse for content sections (default headingLevel=2).
 *
 * `headingLevel={1}` mode turns Section into a page-top element. Use it
 * only when the page top has content immediately attached or is stateful
 * (toggled by id via JS): /mission's tagline, /contact's form/thank-you
 * swap. For purely descriptive page headers (title + descriptive subtitle,
 * nothing else attached), use PageHeader instead.
 */
interface Props {
  id?: string;
  heading?: string;
  headingLevel?: 1 | 2;
  variant?: 'default' | 'tinted';
  density?: 'normal' | 'compact';
  hidden?: boolean;
  class?: string;
}
const {
  id,
  heading,
  headingLevel = 2,
  variant = 'default',
  density = 'normal',
  hidden = false,
  class: classProp,
} = Astro.props;

const HeadingTag = headingLevel === 1 ? 'h1' : 'h2';

const headingClass =
  headingLevel === 1
    ? 'text-3xl md:text-4xl font-semibold mb-4 md:mb-6 text-accent leading-tight tracking-tight'
    : 'text-2xl md:text-3xl font-semibold mb-4 md:mb-6 text-accent leading-tight tracking-tight';

const variantClass = variant === 'tinted' ? 'tinted-section' : '';
const paddingClass = (() => {
  // Page-title sections (h1) get larger top padding to match PageHeader compact,
  // so titles start at the same vertical position across all pages.
  if (headingLevel === 1) {
    if (density === 'compact') return 'pt-16 md:pt-24 pb-8 md:pb-10';
    return 'pt-16 md:pt-24 pb-10 md:pb-16';
  }
  return density === 'compact' ? 'py-8 md:py-10' : 'py-10 md:py-16';
})();
---

<section
  id={id}
  hidden={hidden}
  class={`reveal ${paddingClass} px-6 ${variantClass} ${classProp ?? ''}`}
>
  <div class="max-w-[1080px] mx-auto">
    {heading && (
      <HeadingTag class={headingClass}>
        {heading}
      </HeadingTag>
    )}
    <div class="prose-block">
      <slot />
    </div>
  </div>
</section>

<style>
  .tinted-section {
    position: relative;
    background: rgba(15, 42, 68, 0.03);
  }
  .tinted-section::before,
  .tinted-section::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 50px;
    pointer-events: none;
  }
  .tinted-section::before {
    top: -50px;
    background: linear-gradient(
      to bottom,
      rgba(15, 42, 68, 0) 0,
      rgba(15, 42, 68, 0.03) 100%
    );
  }
  .tinted-section::after {
    bottom: -50px;
    background: linear-gradient(
      to bottom,
      rgba(15, 42, 68, 0.03) 0,
      rgba(15, 42, 68, 0) 100%
    );
  }
</style>
