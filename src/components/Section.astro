---
interface Props {
  id?: string;
  heading?: string;
  variant?: 'default' | 'tinted';
  class?: string;
}
const {
  id,
  heading,
  variant = 'default',
  class: classProp,
} = Astro.props;

const variantClass = variant === 'tinted' ? 'bg-accent/[0.025]' : '';
---

<section
  id={id}
  class={`py-10 md:py-14 px-6 ${variantClass} ${classProp ?? ''}`}
>
  <div class="max-w-[1080px] mx-auto">
    {heading && (
      <h2 class="text-2xl md:text-3xl font-semibold mb-4 md:mb-6 text-accent leading-tight tracking-tight">
        {heading}
      </h2>
    )}
    <div class="prose-block">
      <slot />
    </div>
  </div>
</section>
