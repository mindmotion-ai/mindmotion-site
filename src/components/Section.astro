---
interface Props {
  id?: string;
  heading?: string;
  variant?: 'default' | 'tinted';
  density?: 'normal' | 'compact';
  class?: string;
}
const {
  id,
  heading,
  variant = 'default',
  density = 'normal',
  class: classProp,
} = Astro.props;

const variantClass = variant === 'tinted' ? 'tinted-section' : '';
const paddingClass =
  density === 'compact' ? 'py-8 md:py-10' : 'py-14 md:py-24';
---

<section
  id={id}
  class={`reveal ${paddingClass} px-6 ${variantClass} ${classProp ?? ''}`}
>
  <div class="max-w-[1080px] mx-auto">
    {heading && (
      <h2 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6 text-accent leading-tight tracking-tight">
        {heading}
      </h2>
    )}
    <div class="prose-block">
      <slot />
    </div>
  </div>
</section>

<style>
  .tinted-section {
    background: linear-gradient(
      to bottom,
      rgba(15, 42, 68, 0) 0,
      rgba(15, 42, 68, 0.03) 50px,
      rgba(15, 42, 68, 0.03) calc(100% - 50px),
      rgba(15, 42, 68, 0) 100%
    );
  }
</style>
