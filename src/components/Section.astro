---
interface Props {
  id?: string;
  heading?: string;
  class?: string;
}
const { id, heading, class: classProp } = Astro.props;
---

<section id={id} class={`py-16 md:py-20 px-6 ${classProp ?? ''}`}>
  <div class="max-w-[720px] mx-auto">
    {heading && (
      <h2 class="text-2xl md:text-3xl font-semibold mb-8 text-accent">
        {heading}
      </h2>
    )}
    <div class="prose-block">
      <slot />
    </div>
  </div>
</section>
