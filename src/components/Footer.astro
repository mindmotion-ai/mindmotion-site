---
import { SITE, INSIGHTS_ENABLED } from '../config.ts';
const year = new Date().getFullYear();
---

<footer class="border-t border-accent/10 py-12 px-6 mt-20">
  <div class="max-w-[1100px] mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <img src="/logo-mindmotion.svg" alt="" width="24" height="24" class="h-6 w-auto" />
      <span class="text-sm text-accent-2">© {year} {SITE.legalName}</span>
    </div>
    <ul class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
      <li><a href="/about" class="text-accent hover:text-link">About</a></li>
      <li><a href="/contact" class="text-accent hover:text-link">Contact</a></li>
      {INSIGHTS_ENABLED && (
        <li><a href="/insights" class="text-accent hover:text-link">Insights</a></li>
      )}
      <li><a href="/privacy" class="text-accent hover:text-link">Privacy</a></li>
      <li><a href="/terms" class="text-accent hover:text-link">Terms</a></li>
      <li>
        <a
          href={`https://www.linkedin.com/company/${SITE.org}`}
          class="text-accent hover:text-link"
          rel="noopener"
          target="_blank"
        >
          LinkedIn
        </a>
      </li>
    </ul>
  </div>
</footer>
