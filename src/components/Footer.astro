---
import { SITE } from '../config.ts';
const year = new Date().getFullYear();
---

<footer class="footer-tint pt-20 md:pt-24 pb-14 px-6 mt-4">
  <div class="max-w-[1080px] mx-auto flex flex-col items-center gap-6 text-center">
    <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-base">
      <li><a href="/privacy" class="text-accent hover:text-link">Privacy</a></li>
      <li><a href="/terms" class="text-accent hover:text-link">Terms</a></li>
      <li><a href="/contact" class="text-accent hover:text-link">Contact</a></li>
    </ul>
    <a href="/" aria-label={`${SITE.name} home`} class="inline-block transition-opacity duration-150 hover:opacity-70">
      <img
        src="/logo-mindmotion.svg"
        alt=""
        width="48"
        height="48"
        class="h-12 w-auto"
      />
    </a>
    <p class="text-base text-accent-2">© {year} {SITE.legalName}</p>
  </div>
</footer>

<style>
  .footer-tint {
    background: linear-gradient(
      to bottom,
      rgba(15, 42, 68, 0) 0,
      rgba(15, 42, 68, 0.05) 50px,
      rgba(15, 42, 68, 0.05) 100%
    );
  }
</style>
