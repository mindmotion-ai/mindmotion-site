---
interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  readingTime?: string;
}
const { slug, title, description, date, readingTime } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
}).format(date);
---

<article class="border-b border-accent/10 last:border-b-0 py-8 md:py-10">
  <a href={`/insights/${slug}/`} class="group block">
    <h2 class="text-2xl md:text-3xl font-semibold text-accent leading-tight tracking-tight group-hover:text-link transition-colors">
      {title}
    </h2>
    <p class="mt-2 text-base text-accent-2">
      <span>{formattedDate}</span>
      {readingTime && <span> &middot; {readingTime}</span>}
    </p>
    <p class="mt-3 text-base">
      {description}
    </p>
  </a>
</article>
