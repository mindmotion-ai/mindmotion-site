---
/**
 * Renders an insights-listing entry as semantic content only.
 * Spacing, max-width, tinted-or-not background, and gradient transitions are
 * provided by the surrounding <Section> wrapper on the insights index page,
 * exactly the same way the homepage and Mission page lay out their sections.
 */
interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  readingTime?: string;
}
const { slug, title, description, date, readingTime } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
}).format(date);
---

<article>
  <h2 class="text-2xl md:text-3xl font-semibold leading-tight tracking-tight">
    <a
      href={`/insights/${slug}/`}
      class="text-accent hover:text-link transition-colors"
    >
      {title}
    </a>
  </h2>
  <p class="mt-2 text-base text-accent/70">
    <span>{formattedDate}</span>
    {readingTime && <span> &middot; {readingTime}</span>}
  </p>
  <p class="mt-3 text-base">
    {description}
  </p>
</article>
