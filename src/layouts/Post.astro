---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config.ts';

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  readingTime: string;
  image?: string;
  slug: string;
}
const {
  title,
  description,
  date,
  author,
  readingTime,
  image,
  slug,
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
}).format(date);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  author: { '@type': 'Organization', name: author },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/android-chrome-512x512.png', SITE.url).toString(),
      width: 512,
      height: 512,
    },
  },
  mainEntityOfPage: new URL(`/insights/${slug}/`, SITE.url).toString(),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: SITE.url,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Insights',
      item: new URL('/insights/', SITE.url).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: new URL(`/insights/${slug}/`, SITE.url).toString(),
    },
  ],
};
---

<Base
  title={`${title} | ${SITE.legalName}`}
  description={description}
  canonicalPath={`/insights/${slug}/`}
  ogImage={image ?? '/og-default.png'}
  type="article"
>
  <Nav />
  <main id="main">
    <article class="pt-16 md:pt-24 pb-14 md:pb-24 px-6">
      <div class="max-w-[1080px] mx-auto">
        <h1 class="text-4xl sm:text-5xl md:text-[56px] font-semibold text-accent leading-[1.1] tracking-tight">
          {title}
        </h1>
        <p class="mt-4 text-base text-accent/70">
          <span>{formattedDate}</span>
          <span> &middot; {readingTime}</span>
        </p>
        <p class="mt-6 md:mt-8 text-base">
          {description}
        </p>
        {image && (
          <img
            src={image}
            alt=""
            class="mt-8 md:mt-10 w-full h-auto rounded"
          />
        )}
        <hr class="mt-8 md:mt-10 mb-8 md:mb-10 border-t border-accent/10" />
        <div class="post-body">
          <slot />
        </div>
        <p class="mt-12">
          <a href="/insights/" class="text-accent font-semibold hover:text-link">&larr; Back to Insights</a>
        </p>
      </div>
    </article>
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(articleJsonLd)}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(breadcrumbJsonLd)}
    />
  </main>
  <Footer />
</Base>

<style>
  .post-body :global(p) {
    margin-bottom: 1.5em;
    line-height: 1.7;
  }
  .post-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .post-body :global(h2) {
    font-size: 1.4em;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 2em;
    margin-bottom: 0.75em;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  .post-body :global(h3) {
    font-size: 1.15em;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 1.75em;
    margin-bottom: 0.5em;
  }
  .post-body :global(strong) {
    font-weight: 600;
  }
  .post-body :global(a) {
    color: var(--color-accent);
    font-weight: 600;
  }
  .post-body :global(a):hover {
    color: var(--color-link);
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.5em;
    margin: 1.5em 0;
    color: var(--color-accent-2);
    font-style: italic;
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 1.25em 0 1.5em;
    padding-left: 1.5em;
  }
  .post-body :global(li) {
    margin-bottom: 0.5em;
  }
  .post-body :global(code) {
    background: rgba(15, 42, 68, 0.06);
    padding: 0.1em 0.4em;
    border-radius: 3px;
    font-size: 0.92em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
  .post-body :global(hr) {
    border: 0;
    border-top: 1px solid rgba(15, 42, 68, 0.1);
    margin: 2em 0;
  }
</style>
